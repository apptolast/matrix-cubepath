# Required — change before deploying
SESSION_SECRET=change-this-to-a-long-random-string

# Set to "true" behind HTTPS reverse proxy (Traefik, Caddy, etc.)
# SECURE_COOKIE=true

# Directory for SQLite databases (default: ./data)
# DATA_DIR=/data

# Optional — demo mode
# Set DEMO_USER to seed a demo account with mock data on every startup.
# Visitors can log in and explore without registering.
# DEMO_USER=demo
# DEMO_PASSWORD=demo1234
